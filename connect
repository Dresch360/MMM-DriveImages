#!/usr/bin/env bash
set -e

REMOTE="drive"
FOLDER="mirror-images"
LOCAL="/home/pi/MagicMirror/modules/MMM-DriveImages/public/images"
CONF="/home/pi/.config/rclone/rclone.conf"

clear
echo ""
echo "======================================="
echo " GOOGLE DRIVE PHOTO SETUP"
echo "======================================="
echo ""
echo "======================================="
echo " GOOGLE SIGN-IN REQUIRED"
echo "======================================="
echo ""
echo "When prompted, type EXACTLY:"
echo "1. Use web browser?       -> y"
echo "2. Shared Drive?          -> n"
echo ""
echo "A browser window WILL open."
echo "Sign into your Google account and click Continue."
echo ""
echo "MagicMirror will restart after setup."
echo "If it does not, run: pm2 restart all"
echo ""
echo "DO NOT copy or paste any codes."
echo ""
echo "======================================="
echo ""

mkdir -p /home/pi/.config/rclone

cat > "$CONF" <<EOF
[${REMOTE}]
type = drive
scope = drive
team_drive =
EOF

rclone config reconnect "${REMOTE}:"

echo
echo "Ensuring Google Drive folder exists: ${FOLDER}"
rclone mkdir "${REMOTE}:${FOLDER}"

echo
echo "Syncing photos..."
mkdir -p "$LOCAL"
rclone sync "${REMOTE}:${FOLDER}" "$LOCAL"

echo
echo "Restarting mirror..."
pm2 restart MagicMirror >/dev/null

echo
echo "Done."
echo "Upload photos to the Google Drive folder named: ${FOLDER}"
